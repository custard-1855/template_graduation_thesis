        \PYG{n}{specific\PYGZus{}channels} \PYG{o}{=} \PYG{n}{channels} \PYG{k}{if} \PYG{n}{channels} \PYG{o}{==} \PYG{l+m+mi}{1} \PYG{k}{else} \PYG{n}{channels} \PYG{o}{/}\PYG{o}{/} \PYG{l+m+mi}{2}

        \PYG{c+c1}{\PYGZsh{} Build attention network}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{attention\PYGZus{}network} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{\PYGZus{}build\PYGZus{}attention\PYGZus{}network}\PYG{p}{(}
            \PYG{n}{channels}\PYG{p}{,}
            \PYG{n}{specific\PYGZus{}channels}\PYG{p}{,}
            \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{attention\PYGZus{}type}\PYG{p}{,}
        \PYG{p}{)}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{\PYGZus{}build\PYGZus{}attention\PYGZus{}network}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{in\PYGZus{}channels}\PYG{p}{,} \PYG{n}{mid\PYGZus{}channels}\PYG{p}{,} \PYG{n}{attn\PYGZus{}type}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Build attention network based on specified architecture.}

\PYG{l+s+sd}{        Args:}
\PYG{l+s+sd}{            in\PYGZus{}channels: Input channel dimension}
\PYG{l+s+sd}{            mid\PYGZus{}channels: Intermediate channel dimension}

\PYG{l+s+sd}{        Returns:}
\PYG{l+s+sd}{            Constructed attention network module}

\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{k}{if} \PYG{n}{attn\PYGZus{}type} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{default}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{:}
            \PYG{n}{network} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Sequential}\PYG{p}{(}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Conv1d}\PYG{p}{(}\PYG{n}{in\PYGZus{}channels}\PYG{p}{,} \PYG{n}{mid\PYGZus{}channels}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{3}\PYG{p}{,} \PYG{n}{padding}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{ReLU}\PYG{p}{(}\PYG{p}{)}\PYG{p}{,}
                \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Conv1d}\PYG{p}{(}\PYG{n}{mid\PYGZus{}channels}\PYG{p}{,} \PYG{n}{in\PYGZus{}channels}\PYG{p}{,} \PYG{n}{kernel\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,}
            \PYG{p}{)}
            \PYG{c+c1}{\PYGZsh{} Initialize final layer bias to 1.0 to avoid sigmoid saturation at 0.5}
            \PYG{c+c1}{\PYGZsh{} sigmoid(1.0) = 0.73, providing bias towards mixed features}
            \PYG{n}{nn}\PYG{o}{.}\PYG{n}{init}\PYG{o}{.}\PYG{n}{constant\PYGZus{}}\PYG{p}{(}\PYG{n}{network}\PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{]}\PYG{o}{.}\PYG{n}{bias}\PYG{p}{,} \PYG{l+m+mf}{1.0}\PYG{p}{)}
            \PYG{k}{return} \PYG{n}{network}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{forward}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Forward pass.}

\PYG{l+s+sd}{        Args:}
