\PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{FrequencyAttentionMixStyle}\PYG{p}{(}\PYG{n}{nn}\PYG{o}{.}\PYG{n}{Module}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}CNN\PYGZhy{}based frequency attention MixStyle.}

